{
  "name": "talrum",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/verify-build-css.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "lint:css": "stylelint \"src/**/*.module.css\"",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "supabase test db",
    "test:functions": "cd supabase/functions/delete-account && deno test --allow-env",
    "test:e2e:delete-account": "bash supabase/tests/delete_account_integration_test.sh",
    "icons:gen": "node --experimental-strip-types scripts/gen-icons.ts",
    "migrations:check-drift": "node --experimental-strip-types scripts/check-migration-drift.ts",
    "types:db": "supabase gen types typescript --local > src/types/supabase.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings 0 --no-warn-ignored"
    ],
    "src/**/*.module.css": [
      "stylelint --fix"
    ],
    "*.{ts,tsx,json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/nunito": "^5.1.1",
    "@sentry/react": "^10.55.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/query-async-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "idb-keyval": "^6.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "stylelint": "^17.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "magic-string": "^0.30.17",
    "serialize-javascript": "^7.0.5"
  }
}
