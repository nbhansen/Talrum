VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon key from Supabase dashboard → Project Settings → API>
# Sentry DSN — optional; the SDK no-ops without it. In CI it comes from the
# VITE_SENTRY_DSN GitHub secret (deploy-pages.yml), not from an env file.
VITE_SENTRY_DSN=
